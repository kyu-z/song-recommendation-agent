{
  "youtube_audio_library": {
    "enabled": true,
    "max_downloads": 20,
    "genres": ["ambient", "hyperpop", "phonk", "city pop", "vaporwave", 
      "k-pop", "afrobeats", "drum and bass", "house", "future bass",
      "cyberpunk", "glitch", "lo-fi", "synthwave", "j-rock", "chillwave"],
    "search_terms": {
      "ambient": ["ambient music no copyright", "royalty free ambient", "creative commons ambient"],
      "hyperpop": ["hyperpop no copyright", "royalty free hyperpop", "creative commons hyperpop"],
      "phonk": ["phonk music no copyright", "royalty free phonk", "creative commons phonk"],
      "city pop": ["city pop no copyright", "royalty free city pop", "creative commons city pop"],
      "vaporwave": ["vaporwave no copyright", "royalty free vaporwave", "creative commons vaporwave"],
      "k-pop": ["k-pop instrumental no copyright", "royalty free kpop", "creative commons k-pop"],
      "afrobeats": ["afrobeats no copyright", "royalty free afrobeats", "creative commons afrobeats"],
      "drum and bass": ["drum and bass no copyright", "royalty free dnb", "creative commons drum bass"],
      "house": ["house music no copyright", "royalty free house", "creative commons house"],
      "future bass": ["future bass no copyright", "royalty free future bass", "creative commons future bass"],
      "cyberpunk": ["cyberpunk music no copyright", "royalty free cyberpunk", "creative commons cyberpunk"],
      "glitch": ["glitch music no copyright", "royalty free glitch", "creative commons glitch"],
      "electronic": ["electronic music no copyright", "royalty free electronic", "creative commons electronic"],
      "lo-fi": ["lo-fi music no copyright", "royalty free lofi", "creative commons lo-fi"],
      "synthwave": ["synthwave no copyright", "royalty free synthwave", "creative commons synthwave"],
      "j-rock": ["j-rock instrumental no copyright", "royalty free j-rock", "creative commons japanese rock"],
      "chillwave": ["chillwave no copyright", "royalty free chillwave", "creative commons chillwave"],
      "instrumental": ["instrumental music no copyright", "royalty free instrumental"]
    },
    "filters": {
      "duration_min": 60,
      "duration_max": 600,
      "exclude_terms": ["remix", "cover", "karaoke", "lyrics"]
    }
  },
  "freesound": {
    "enabled": true,
    "api_key": "ENV:FREESOUND_API_KEY",
    "max_downloads": 15,
    "tags": [
      "music", "instrumental", "ambient", "electronic", "cinematic", "atmospheric", 
      "hyperpop", "phonk", "vaporwave", "synthwave", "chillwave", "glitch", 
      "cyberpunk", "house", "drum-and-bass", "future-bass", "afrobeats",
      "cityPop", "kpop", "jrock", "lofi", "chill", "downtempo", "experimental",
      "retrowave", "synthpop", "electronica", "beats", "ambient-electronic",
      "techno", "minimal", "deep-house", "progressive", "trance"
    ],
    "duration_range": [60, 300],
    "quality_filters": {
      "min_rating": 3,
      "min_downloads": 100
    },
    "api_url": "https://freesound.org/apiv2/search/text/",
    "register_url": "https://freesound.org/apiv2/apply/"
  },
  "jamendo": {
    "enabled": true,
    "api_key": "ENV:JAMENDO_CLIENT_ID",
    "max_downloads": 10,
    "genres": [
      "electronic", "instrumental", "ambient", "chillout", "soundtrack",
      "hyperpop", "phonk", "vaporwave", "synthwave", "chillwave", "glitch",
      "cyberpunk", "house", "drum-and-bass", "future-bass", "afrobeats",
      "downtempo", "electronica", "techno", "experimental", "chill",
      "synthpop", "retrowave", "lofi", "beats", "atmospheric",
      "minimal", "deep-house", "progressive", "trance", "dubstep"
    ],
    "api_url": "https://api.jamendo.com/v3.0/tracks/",
    "register_url": "https://developer.jamendo.com/"
  },
  "archive_org": {
    "enabled": true,
    "max_downloads": 10,
    "collections": [
      "opensource_audio",
      "netlabels",
      "freemusicarchive"
    ],
    "api_url": "https://archive.org/advancedsearch.php"
  },
  "ccmixter": {
    "enabled": false,
    "max_downloads": 5,
    "api_url": "http://ccmixter.org/api/",
    "note": "Creative Commons remixes and original tracks"
  },
  "download_settings": {
    "format": "mp3",
    "quality": "192",
    "max_duration": 600,
    "min_duration": 30,
    "rate_limit_delay": [1, 3],
    "retry_attempts": 3,
    "timeout": 30
  },
  "gtzan_avoidance": {
    "blocked_genres": [
      "blues", "classical", "country", "disco", "hiphop",
      "jazz", "metal", "pop", "reggae", "rock"
    ],
    "blocked_aliases": {
      "hip-hop": "hiphop",
      "hip hop": "hiphop",
      "classical music": "classical",
      "country music": "country",
      "pop music": "pop",
      "rock music": "rock",
      "jazz music": "jazz",
      "blues music": "blues",
      "heavy metal": "metal",
      "death metal": "metal",
      "reggae music": "reggae"
    },
    "allowed_subgenres": {
      "electronic": ["ambient", "idm", "techno", "house", "downtempo"],
      "instrumental": ["post-rock", "neoclassical", "film score"],
      "experimental": ["noise", "drone", "soundscape"]
    }
  }
}
